<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Acl/etc/acl.xsd">
    <acl>
        <resources>
            <resource id="Magento_Backend::admin">
                <resource id="MageUpgrade_AutoUpgrader::main" title="AutoUpgrader" sortOrder="100">
                    <resource id="MageUpgrade_AutoUpgrader::dashboard" title="Upgrade Dashboard" sortOrder="10"/>
                    <resource id="MageUpgrade_AutoUpgrader::scan" title="Run Compatibility Scan" sortOrder="20"/>
                    <resource id="MageUpgrade_AutoUpgrader::upgrade" title="Execute Upgrade" sortOrder="30"/>
                    <resource id="MageUpgrade_AutoUpgrader::history" title="Upgrade History" sortOrder="40"/>
                    <resource id="MageUpgrade_AutoUpgrader::config" title="Configuration" sortOrder="50"/>
                </resource>
            </resource>
        </resources>
    </acl>
</config>
