<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">

    <!-- Upgrade log / history table -->
    <table name="mageupgrade_upgrade_log" resource="default" engine="innodb"
           comment="AutoUpgrader - Upgrade History Log">
        <column xsi:type="int" name="upgrade_id" unsigned="true" nullable="false" identity="true" comment="Upgrade ID"/>
        <column xsi:type="varchar" name="from_version" nullable="false" length="32" comment="Source Magento Version"/>
        <column xsi:type="varchar" name="to_version" nullable="false" length="32" comment="Target Magento Version"/>
        <column xsi:type="varchar" name="status" nullable="false" length="32" default="pending"
                comment="Status: pending|scanning|fixing|upgrading|compiling|deploying|completed|failed|rolled_back"/>
        <column xsi:type="int" name="progress_percent" unsigned="true" nullable="false" default="0" comment="Progress Percentage"/>
        <column xsi:type="varchar" name="current_step" nullable="true" length="128" comment="Current Step Label"/>
        <column xsi:type="text" name="steps_log" nullable="true" comment="JSON array of step details"/>
        <column xsi:type="text" name="error_message" nullable="true" comment="Error message if failed"/>
        <column xsi:type="varchar" name="backup_path" nullable="true" length="512" comment="Backup file path"/>
        <column xsi:type="int" name="scan_id" unsigned="true" nullable="true" comment="Related Scan ID"/>
        <column xsi:type="varchar" name="initiated_by" nullable="true" length="128" comment="Admin user or CLI"/>
        <column xsi:type="timestamp" name="started_at" nullable="true" comment="Upgrade Start Time"/>
        <column xsi:type="timestamp" name="completed_at" nullable="true" comment="Upgrade End Time"/>
        <column xsi:type="timestamp" name="created_at" on_update="false" nullable="false" default="CURRENT_TIMESTAMP" comment="Created At"/>
        <column xsi:type="timestamp" name="updated_at" on_update="true" nullable="false" default="CURRENT_TIMESTAMP" comment="Updated At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="upgrade_id"/>
        </constraint>
        <index referenceId="MAGEUPGRADE_UPGRADE_LOG_STATUS" indexType="btree">
            <column name="status"/>
        </index>
    </table>

    <!-- Compatibility scan results table -->
    <table name="mageupgrade_scan_result" resource="default" engine="innodb"
           comment="AutoUpgrader - Compatibility Scan Results">
        <column xsi:type="int" name="scan_id" unsigned="true" nullable="false" identity="true" comment="Scan ID"/>
        <column xsi:type="varchar" name="current_version" nullable="false" length="32" comment="Current Magento Version"/>
        <column xsi:type="varchar" name="target_version" nullable="false" length="32" comment="Target Magento Version"/>
        <column xsi:type="varchar" name="status" nullable="false" length="32" default="running"
                comment="Status: running|completed|failed"/>
        <column xsi:type="int" name="total_issues" unsigned="true" nullable="false" default="0" comment="Total Issues Found"/>
        <column xsi:type="int" name="critical_issues" unsigned="true" nullable="false" default="0" comment="Critical Issues"/>
        <column xsi:type="int" name="warnings" unsigned="true" nullable="false" default="0" comment="Warning Issues"/>
        <column xsi:type="int" name="auto_fixable" unsigned="true" nullable="false" default="0" comment="Auto-fixable Issues"/>
        <column xsi:type="mediumtext" name="issues_json" nullable="true" comment="Full scan results as JSON"/>
        <column xsi:type="mediumtext" name="extensions_json" nullable="true" comment="Extension compatibility data as JSON"/>
        <column xsi:type="mediumtext" name="impacted_files_json" nullable="true" comment="List of impacted files as JSON"/>
        <column xsi:type="timestamp" name="created_at" on_update="false" nullable="false" default="CURRENT_TIMESTAMP" comment="Created At"/>
        <column xsi:type="timestamp" name="completed_at" nullable="true" comment="Scan Completed At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="scan_id"/>
        </constraint>
    </table>

    <!-- Individual issue details table -->
    <table name="mageupgrade_scan_issue" resource="default" engine="innodb"
           comment="AutoUpgrader - Individual Scan Issues">
        <column xsi:type="int" name="issue_id" unsigned="true" nullable="false" identity="true" comment="Issue ID"/>
        <column xsi:type="int" name="scan_id" unsigned="true" nullable="false" comment="Related Scan ID"/>
        <column xsi:type="varchar" name="severity" nullable="false" length="16" comment="critical|error|warning|info"/>
        <column xsi:type="varchar" name="category" nullable="false" length="64" comment="Issue category"/>
        <column xsi:type="varchar" name="file_path" nullable="false" length="512" comment="Affected file path"/>
        <column xsi:type="int" name="line_number" unsigned="true" nullable="true" comment="Line number"/>
        <column xsi:type="text" name="description" nullable="false" comment="Issue description"/>
        <column xsi:type="text" name="suggestion" nullable="true" comment="Fix suggestion"/>
        <column xsi:type="boolean" name="is_auto_fixable" nullable="false" default="false" comment="Can be auto-fixed"/>
        <column xsi:type="boolean" name="is_fixed" nullable="false" default="false" comment="Has been fixed"/>
        <column xsi:type="varchar" name="module_name" nullable="true" length="128" comment="Related module name"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="issue_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="MAGEUPGRADE_SCAN_ISSUE_SCAN_ID"
                    table="mageupgrade_scan_issue" column="scan_id"
                    referenceTable="mageupgrade_scan_result" referenceColumn="scan_id"
                    onDelete="CASCADE"/>
        <index referenceId="MAGEUPGRADE_SCAN_ISSUE_SCAN_ID" indexType="btree">
            <column name="scan_id"/>
        </index>
        <index referenceId="MAGEUPGRADE_SCAN_ISSUE_SEVERITY" indexType="btree">
            <column name="severity"/>
        </index>
    </table>

</schema>
