        "magento/module-backend": ">=102.0.8",
        "magento/module-ui": ">=101.2.8",
        "magento/module-store": ">=101.1.8",
        "magento/module-config": ">=101.2.8"
    },
    "autoload": {
        "files": [
            "registration.php"
